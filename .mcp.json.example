{
  "mcpServers": {
    "gigablocks-database": {
      "command": "/path/to/repo/packages/mcp-database/node_modules/.bin/tsx",
      "args": ["/path/to/repo/packages/mcp-database/src/index.ts"],
      "env": {
        "DATABASE_URL": "postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"
      }
    }
  }
}
