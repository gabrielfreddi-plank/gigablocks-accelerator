# PostHog MCP Server — copy this file to .env.local and fill in your values

# Personal API Key — generate at: PostHog → Settings → User → Personal API Keys
POSTHOG_API_KEY=phx_...

# Project ID — found in PostHog → Project Settings URL: /project/<id>/settings
POSTHOG_PROJECT_ID=394729

# API host — use https://eu.posthog.com if your project is on the EU cloud
# POSTHOG_HOST=https://us.posthog.com
