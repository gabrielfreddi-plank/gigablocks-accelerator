    "@supabase/supabase-js": "^2.104.0",
    "@tailwindcss/postcss": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.0",
    "posthog-js": "^1.371.2",
    "posthog-node": "^5.30.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shadcn": "^4.3.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
