    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.5.0",
    "jsdom": "^29.0.2",
    "pg": "^8.20.0",
    "prettier": "^3.7.4",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.50.0",
